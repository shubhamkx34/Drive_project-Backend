<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.css" rel="stylesheet" />

  </head>
  <body class="bg-gray-800  min-h-screen w-screen ">
  <div class=" flex items-center justify-center mt-30">
   
       <form action="/user/register" method="post">
        <div class=" mb-20">
            <label for="first_name" class="block  text-lg font-medium text-white text-heading">Username</label>
            <input type="text" id="first_name" class="rounded-4xl  text-sm rounded-base px-20 shadow-xs placeholder:text-body" placeholder="John" name = username required
            />
        </div>
   
     <div class="mb-20">
        <label for="email" class="block  text-lg font-medium text-white text-heading">Email address</label>
        <input type="email" id="email" class="rounded-4xl  text-sm rounded-base px-20 shadow-xs placeholder:text-body" placeholder="john.doe@company.com" name = email required />
    </div> 
    <div class="mb-20">
        <label for="password" class="block  text-lg font-medium text-white text-heading">Password</label>
        <input type="password" id="password" class="rounded-4xl  text-sm rounded-base px-20 shadow-xs placeholder:text-body" placeholder="•••••••••" name =password username required />
    </div> 
    <div class="mb-15 mt-20">
     <button type="submit" class="border-4 rounded-4xl text-white mx-20 h-20 w-40 ">Submit</button></div>
 </div>
    <script src="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.js"></script>
  </body>
</html>